# Dependency directories
node_modules/
jspm_packages/

# Production build output
build/
dist/
public/build/
out/
.next/ # For Next.js projects

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage directory
coverage/
.nyc_output/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Optional caches
.npm/
.eslintcache
.cache/
.parcel-cache/

# IDE-specific files
.idea/         # JetBrains IDEs (IntelliJ, WebStorm, etc.)
.vscode/       # VS Code
*.iml          # JetBrains project files

# OS-specific files
.DS_Store      # macOS
Thumbs.db      # Windows

# Output of 'npm pack'
*.tgz

# Yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*

# TypeScript cache
*.tsbuildinfo